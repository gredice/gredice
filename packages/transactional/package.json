        "@types/node": "24.12.4",
        "@types/react": "19.2.17",
        "tailwindcss": "4.3.2",
        "tsx": "4.23.0",
        "typescript": "6.0.3"
    },
    "dependencies": {
        "@gredice/js": "workspace:*",
        "react": "19.2.7",
        "react-email": "6.6.9"
    }
}
