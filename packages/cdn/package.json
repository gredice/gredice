{
    "name": "@gredice/cdn",
    "version": "0.0.0",
    "private": true,
    "sideEffects": false,
    "type": "module",
    "license": "MIT",
    "scripts": {
        "clean": "rimraf .turbo dist build out coverage tsconfig.tsbuildinfo",
        "lint": "biome check --write",
        "lint:migrate": "biome migrate --write",
        "regenerate-cdn": "pnpm run /^regenerate-cdn:.*/",
        "regenerate-cdn:decoration-atlas": "node --experimental-strip-types ./scripts/extract-decoration-sprites.ts --input apps/garden/data/sriptes/grass_grass_examples.png --output-dir apps/garden/data/sriptes/extracted/ground-cover/grass --min-alpha 24 --min-pixels 1400 --merge-gap 48 --padding 24 --limit 8 && node --experimental-strip-types ./scripts/extract-decoration-sprites.ts --input apps/garden/data/sriptes/desert_grass_examples.png --output-dir apps/garden/data/sriptes/extracted/ground-cover/desert --min-alpha 24 --min-pixels 1400 --merge-gap 48 --padding 24 --limit 8 && node --experimental-strip-types ./scripts/create-decoration-atlas.ts --input-dir apps/garden/data/sriptes/extracted/ground-cover --output-png apps/garden/public/assets/sprites/decorations/ground-cover.atlas.png --padding 16 --size 2048 --columns 4 --rows 4",
        "regenerate-cdn:sounds": "node --env-file=.env --experimental-strip-types ./scripts/regenerate-sounds.ts"
    },
    "devDependencies": {
        "@aws-sdk/client-s3": "3.1041.0",
        "@biomejs/biome": "2.4.14",
        "@ffmpeg-installer/ffmpeg": "1.1.0",
        "@types/node": "24.12.2",
        "sharp": "0.34.5"
    }
}
