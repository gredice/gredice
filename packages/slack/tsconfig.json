{
    "compilerOptions": {
        "lib": ["esnext", "DOM"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "moduleDetection": "force",
        "incremental": true,
        "target": "ESNext"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
