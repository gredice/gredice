{
    "name": "farm",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "rimraf .next .turbo dist build out coverage .vercel storybook-static",
        "lint": "biome check --write",
        "lint:migrate": "biome migrate --write",
        "dev": "node ../../scripts/run-app-command.mjs dev",
        "build": "next build",
        "start": "node ../../scripts/run-app-command.mjs start",
        "test": "pnpm run test:run",
        "test:prepare": "turbo build --filter=farm",
        "test:run": "playwright test",
        "test-ui": "pnpm run test:prepare && playwright test --ui",
        "test:local": "pnpm run test:prepare && pnpm run test:run"
    },
    "dependencies": {
        "@opentelemetry/api-logs": "0.219.0",
        "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
        "@opentelemetry/resources": "2.8.0",
        "@opentelemetry/sdk-logs": "0.219.0",
        "@posthog/next": "0.7.0",
        "@vercel/blob": "2.5.0",
        "@vercel/toolbar": "0.2.6",
        "flags": "4.2.0",
        "next": "16.2.9",
        "pg": "8.22.0",
        "react": "19.2.7",
        "react-dom": "19.2.7",
        "server-only": "0.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@gredice/auth": "workspace:*",
        "@gredice/client": "workspace:*",
        "@gredice/js": "workspace:*",
        "@gredice/label-printer": "workspace:*",
        "@gredice/storage": "workspace:*",
        "@gredice/ui": "workspace:*",
        "@mdxeditor/editor": "4.0.4",
        "@playwright/experimental-ct-react": "1.61.1",
        "@playwright/test": "1.61.1",
        "@tailwindcss/postcss": "4.3.2",
        "@tailwindcss/typography": "0.5.20",
        "@tanstack/react-query": "5.101.2",
        "@types/node": "24.12.4",
        "@types/react": "19.2.17",
        "@types/react-dom": "19.2.3",
        "@vercel/analytics": "2.0.1",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "postcss": "8.5.16",
        "tailwindcss": "4.3.2",
        "typescript": "6.0.3"
    }
}
