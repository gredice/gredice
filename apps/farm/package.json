{
    "name": "farm",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "rimraf .next .turbo dist build out coverage .vercel storybook-static",
        "lint": "biome check --write",
        "lint:migrate": "biome migrate --write",
        "dev": "next dev -p 3002",
        "build": "next build",
        "start": "next start -p 3002",
        "test": "pnpm run /^test:.*/",
        "test:prepare": "pnpm --dir ../.. exec turbo build --filter=farm",
        "test:run": "pnpm run test:prepare && playwright test",
        "test-ui": "pnpm run test:prepare && playwright test --ui",
        "regenerate": "pnpm run /^regenerate:.*/",
        "regenerate:feature-flags": "hypertune && node ../../scripts/sync-flags.mjs apps/farm"
    },
    "dependencies": {
        "@flags-sdk/hypertune": "0.3.2",
        "@opentelemetry/api-logs": "0.214.0",
        "@opentelemetry/exporter-logs-otlp-http": "0.214.0",
        "@opentelemetry/resources": "2.6.1",
        "@opentelemetry/sdk-logs": "0.214.0",
        "@posthog/next": "0.1.0",
        "@vercel/blob": "2.3.3",
        "@vercel/toolbar": "0.2.2",
        "flags": "4.0.6",
        "hypertune": "2.10.1",
        "next": "16.2.4",
        "pg": "8.20.0",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "server-only": "0.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@gredice/client": "workspace:*",
        "@gredice/js": "workspace:*",
        "@gredice/storage": "workspace:*",
        "@gredice/ui": "workspace:*",
        "@mdxeditor/editor": "3.54.1",
        "@playwright/experimental-ct-react": "1.59.1",
        "@playwright/test": "1.59.1",
        "@signalco/auth-client": "0.3.0",
        "@signalco/auth-server": "0.5.3",
        "@signalco/hooks": "0.2.1",
        "@signalco/js": "0.1.0",
        "@signalco/ui": "0.2.10",
        "@signalco/ui-icons": "0.2.2",
        "@signalco/ui-primitives": "0.6.5",
        "@signalco/ui-themes-minimal-app": "0.1.3",
        "@tailwindcss/typography": "0.5.19",
        "@tanstack/react-query": "5.99.0",
        "@types/node": "24.12.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vercel/analytics": "2.0.1",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "postcss": "8.5.10",
        "tailwindcss": "3.4.19",
        "typescript": "6.0.3"
    }
}
