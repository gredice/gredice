{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "installCommand": "pnpm install --frozen-lockfile",
    "crons": [
        {
            "path": "/api/stripe/cron",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/internal/cron/notifications-digest",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/internal/cron/web-push",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/internal/cron/auto-close-slots",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/internal/cron/delivery-survey",
            "schedule": "0 * 1,2 * *"
        },
        {
            "path": "/api/internal/cron/delivery-ready-emails",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/internal/cron/delivery-lifecycle-emails",
            "schedule": "* * * * *"
        },
        {
            "path": "/api/internal/cron/delivery-notification-health",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/internal/cron/delivery-lifecycle-reconciliation",
            "schedule": "* * * * *"
        },
        {
            "path": "/api/internal/cron/delivery-tracking-retention",
            "schedule": "* * * * *"
        },
        {
            "path": "/api/internal/cron/update-farm-weather",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/internal/cron/achievements",
            "schedule": "0 * * * *"
        },
        {
            "path": "/api/internal/cron/automations",
            "schedule": "* * * * *"
        },
        {
            "path": "/api/internal/cron/garden-preview-blobs",
            "schedule": "23 3 * * *"
        },
        {
            "path": "/api/internal/cron/garden-preview-blob-deletions",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/internal/cron/outlet-lifecycle",
            "schedule": "*/5 * * * *"
        },
        {
            "path": "/api/internal/cron/social-publishing",
            "schedule": "*/5 * * * *"
        }
    ]
}
