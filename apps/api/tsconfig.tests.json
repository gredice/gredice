{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "incremental": false
    },
    "include": [
        "next-env.d.ts",
        ".next/types/**/*.ts",
        ".next\\dev/types/**/*.ts",
        ".next/dev/types/**/*.ts",
        "**/*.spec.ts",
        "**/*.spec.tsx",
        "**/*.unit.ts",
        "**/*.unit.tsx",
        "tests/**/*.ts",
        "tests/**/*.tsx"
    ],
    "exclude": ["node_modules"]
}
