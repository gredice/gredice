{
    "name": "api",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        "./routes": "./export/index.ts"
    },
    "scripts": {
        "clean": "rimraf .next .turbo dist build out coverage .vercel storybook-static",
        "lint": "biome check --write",
        "lint:migrate": "biome migrate --write",
        "dev": "next dev -p 3005",
        "build": "next build",
        "start": "next start -p 3005",
        "test": "pnpm run /^test:.*/",
        "test:run": "playwright test",
        "test:node": "node --import tsx --test --conditions=react-server ./lib/**/*.node.spec.ts",
        "merge:raised-beds:all": "node --conditions=react-server --env-file=.env --import tsx ./scripts/mergeAllRaisedBeds.ts",
        "regenerate": "pnpm run /^regenerate:.*/",
        "regenerate:directories-api": "pnpm dlx openapi-typescript https://api.gredice.com/api/docs/directories -o ./lib/@types/directories-api/v1.d.ts"
    },
    "dependencies": {
        "@date-fns/tz": "1.4.1",
        "@hono/mcp": "0.2.5",
        "@hono/standard-validator": "0.2.2",
        "@modelcontextprotocol/sdk": "1.29.0",
        "@opentelemetry/api-logs": "0.214.0",
        "@opentelemetry/exporter-logs-otlp-http": "0.214.0",
        "@opentelemetry/resources": "2.6.1",
        "@opentelemetry/sdk-logs": "0.214.0",
        "@posthog/next": "0.1.0",
        "@scalar/api-reference-react": "0.9.22",
        "@standard-community/standard-json": "0.3.5",
        "@standard-community/standard-openapi": "0.2.9",
        "@upstash/redis": "1.37.0",
        "@valibot/to-json-schema": "1.6.0",
        "ai": "6.0.162",
        "date-fns": "4.1.0",
        "hono": "4.12.14",
        "hono-openapi": "1.3.0",
        "next": "16.2.3",
        "pg": "8.20.0",
        "prettier": "3.8.3",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "server-only": "0.0.1",
        "valibot": "1.3.1",
        "xml2js": "0.6.2",
        "zod": "4.3.6",
        "zod-openapi": "5.4.6",
        "zod-to-json-schema": "3.25.2"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.12",
        "@gredice/directory-types": "workspace:*",
        "@gredice/email": "workspace:*",
        "@gredice/js": "workspace:*",
        "@gredice/notifications": "workspace:*",
        "@gredice/signalco": "workspace:*",
        "@gredice/storage": "workspace:*",
        "@gredice/stripe": "workspace:*",
        "@gredice/transactional": "workspace:*",
        "@playwright/test": "1.59.1",
        "@signalco/auth-server": "0.5.3",
        "@signalco/hooks": "0.2.1",
        "@signalco/js": "0.1.0",
        "@signalco/ui": "0.2.10",
        "@signalco/ui-icons": "0.2.2",
        "@signalco/ui-primitives": "0.6.5",
        "@signalco/ui-themes-minimal-app": "0.1.3",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "24.12.2",
        "@types/pg": "8.20.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/xml2js": "0.4.14",
        "@vercel/analytics": "2.0.1",
        "jsonwebtoken": "9.0.3",
        "openapi-types": "12.1.3",
        "postcss": "8.5.10",
        "tailwindcss": "4.2.2",
        "tsx": "4.21.0",
        "typescript": "6.0.2"
    }
}
