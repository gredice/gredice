{
    "name": "storybook",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "rimraf .turbo dist build out coverage .vercel storybook-static",
        "lint": "biome check --write",
        "lint:migrate": "biome migrate --write",
        "dev": "storybook dev -p 3004 --no-open",
        "storybook": "storybook dev -p 3004 --no-open",
        "build": "storybook build --output-dir storybook-static",
        "build-storybook": "storybook build --output-dir storybook-static"
    },
    "dependencies": {
        "@gredice/ui": "workspace:*",
        "@signalco/ui": "0.2.10",
