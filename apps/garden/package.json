{
    "name": "garden",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "clean": "rimraf .next .turbo dist build out coverage .vercel storybook-static",
        "lint": "biome check --write",
        "lint:migrate": "biome migrate --write",
        "dev": "next dev -p 3001",
        "build": "next build",
        "start": "next start -p 3001",
        "test": "pnpm run /^test:.*/",
        "test:prepare": "pnpm --dir ../.. exec turbo build --filter=garden",
        "test:run": "pnpm run test:prepare && playwright test",
        "test-ui": "pnpm run test:prepare && playwright test --ui",
        "regenerate": "pnpm run /^regenerate:.*/",
        "regenerate:feature-flags": "hypertune && node ../../scripts/sync-flags.mjs apps/garden",
        "generate:models-types": "pnpm dlx gltfjsx ./public/assets/models/GameAssets.glb --types --typeonly --output ../../packages/game/src/models/GameAssets.tsx && node ../../scripts/fix-gltfjsx-output.mjs"
    },
    "dependencies": {
        "@flags-sdk/hypertune": "0.3.2",
        "@opentelemetry/api-logs": "0.215.0",
        "@opentelemetry/exporter-logs-otlp-http": "0.215.0",
        "@opentelemetry/resources": "2.7.0",
        "@opentelemetry/sdk-logs": "0.215.0",
        "@posthog/next": "0.1.0",
        "@vercel/toolbar": "0.2.2",
        "flags": "4.0.6",
        "hypertune": "2.10.1",
        "next": "16.2.4",
        "next-themes": "0.4.6",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "server-only": "0.0.1"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@gredice/client": "workspace:*",
        "@gredice/game": "workspace:*",
        "@gredice/ui": "workspace:*",
        "@playwright/experimental-ct-react": "1.59.1",
        "@playwright/test": "1.59.1",
        "@signalco/auth-client": "0.3.0",
        "@signalco/auth-server": "0.5.3",
        "@signalco/hooks": "0.2.1",
        "@signalco/js": "0.1.0",
        "@signalco/ui": "0.2.10",
        "@signalco/ui-icons": "0.2.2",
        "@signalco/ui-notifications": "0.2.0",
        "@signalco/ui-primitives": "0.6.5",
        "@signalco/ui-themes-minimal": "0.1.3",
        "@tailwindcss/typography": "0.5.19",
        "@tanstack/react-query": "5.100.1",
        "@types/node": "24.12.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vercel/analytics": "2.0.1",
        "babel-plugin-react-compiler": "19.1.0-rc.3",
        "postcss": "8.5.10",
        "sass": "1.99.0",
        "tailwindcss": "3.4.19",
        "tailwindcss-animate": "1.0.7",
        "typescript": "6.0.3"
    }
}
