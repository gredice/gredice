# Local smoke/default values (safe placeholders)
NEXT_PUBLIC_VERCEL_ENV=development
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_UI_HOST=
POSTHOG_SERVER_HOST=
POSTHOG_PROXY_HOST=
GREDICE_JWT_SIGN_SECRET=local-dev-sign-secret

# Optional integration values
COOKIE_DOMAIN=
GREDICE_WWW_REVALIDATE_URL=
GREDICE_WWW_REVALIDATE_SECRET=
SOCIAL_PUBLISHING_QUEUE_SECRET=
CRON_SECRET=

# Social publishing provider config (server-only; do not use NEXT_PUBLIC_ for secrets)
SOCIAL_PROVIDER_REDDIT_ENABLED=false
SOCIAL_PROVIDER_REDDIT_CLIENT_ID=
SOCIAL_PROVIDER_REDDIT_CLIENT_SECRET=
SOCIAL_PROVIDER_REDDIT_USER_AGENT=
SOCIAL_PROVIDER_REDDIT_DEFAULT_DESTINATION=
SOCIAL_PROVIDER_REDDIT_ALLOWED_DESTINATIONS=

# Generic social publishing bridge config for providers without a direct adapter.
# *_PUBLISH_ENDPOINT receives POST JSON with provider, account key, destination,
# post type, title/body/url, and mediaUrls. *_API_KEY is sent as Bearer auth.
SOCIAL_PROVIDER_INSTAGRAM_ENABLED=false
SOCIAL_PROVIDER_INSTAGRAM_PUBLISH_ENDPOINT=
SOCIAL_PROVIDER_INSTAGRAM_API_KEY=
SOCIAL_PROVIDER_INSTAGRAM_DEFAULT_DESTINATION=
SOCIAL_PROVIDER_INSTAGRAM_ALLOWED_DESTINATIONS=
